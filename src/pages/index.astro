---
import Base from '@layouts/Base.astro';
import { fetchZennEntries, formatDate, getBlogEntries, sortNewestFirst } from '@lib/writing';

const HOME_LIMIT = 12;
const [zenn, blog] = await Promise.all([fetchZennEntries(), getBlogEntries()]);
const all = sortNewestFirst([...zenn, ...blog]);
const writing = all.slice(0, HOME_LIMIT);
const hasMore = all.length > HOME_LIMIT;

const projects = [
  {
    name: 'asterel',
    desc: 'Rust で書いているコンパニオン AI ランタイム。記憶と人格を構造で扱う。',
    href: 'https://github.com/asterel-rs/asterel',
  },
];

const contact = [
  { label: 'github', href: 'https://github.com/haru0416-dev', aria: 'GitHub プロフィール' },
  { label: 'zenn', href: 'https://zenn.dev/haru0416', aria: 'Zenn の記事一覧' },
  { label: 'mail', href: 'mailto:haru_0416@pm.me', aria: 'メールを送る' },
];
---

<Base>
  <header class="masthead">
    <h1>haru</h1>
  </header>

  <section class="field" id="writing" aria-labelledby="writing-label">
    <h2 class="field-label" id="writing-label"><span>W</span>riting</h2>
    {
      writing.length === 0 ? (
        <p class="empty">準備中。</p>
      ) : (
        <ol class="entries">
          {writing.map((entry) => (
            <li class="entry-row">
              <a
                class="entry-link"
                href={entry.href}
                target={entry.external ? '_blank' : undefined}
                rel={entry.external ? 'noopener noreferrer' : undefined}
              >
                <div class="margin">
                  <time datetime={entry.pubDate.toISOString()}>
                    {formatDate(entry.pubDate)}
                  </time>
                  <span class="source">{entry.source}</span>
                </div>
                <div class="body">
                  <span class="title">{entry.title}</span>
                </div>
              </a>
            </li>
          ))}
        </ol>
      )
    }
    {hasMore && (
      <a class="more-link" href="/writing">
        more in archive
      </a>
    )}
  </section>

  <section class="field" id="projects" aria-labelledby="projects-label">
    <h2 class="field-label" id="projects-label"><span>P</span>rojects</h2>
    <ol class="entries">
      {
        projects.map((p) => (
          <li class="entry-row">
            <a class="entry-link" href={p.href} target="_blank" rel="noopener noreferrer">
              <div class="margin">
                <span class="name">{p.name}</span>
              </div>
              <div class="body">
                <span class="desc">{p.desc}</span>
              </div>
            </a>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="field" id="contact" aria-labelledby="contact-label">
    <h2 class="field-label" id="contact-label"><span>C</span>ontact</h2>
    <ul class="contact">
      {
        contact.map((c) => (
          <li>
            <a
              href={c.href}
              aria-label={c.aria}
              target={c.href.startsWith('mailto:') ? undefined : '_blank'}
              rel={c.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
            >
              {c.label}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Base>
