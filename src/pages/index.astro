---
import Base from '@layouts/Base.astro';
import { fetchZennEntries, getNoteEntries, groupByYear, sortNewestFirst } from '@lib/writing';

const [zenn, notes] = await Promise.all([fetchZennEntries(), getNoteEntries()]);
const writingGroups = groupByYear(sortNewestFirst([...zenn, ...notes]));

const projects = [
  {
    name: 'asterel',
    desc: 'Rust で書いているコンパニオン AI ランタイム。記憶と人格を構造で扱う。',
    href: 'https://github.com/asterel-rs/asterel',
  },
];

const contact = [
  { label: 'github', href: 'https://github.com/haru0416-dev', aria: 'GitHub プロフィール' },
  { label: 'zenn', href: 'https://zenn.dev/haru0416', aria: 'Zenn の記事一覧' },
  { label: 'mail', href: 'mailto:haru_0416@pm.me', aria: 'メールを送る' },
];
---

<Base>
  <header class="masthead">
    <h1>haru0416</h1>
  </header>

  <section class="field" id="writing" aria-labelledby="writing-label">
    <h2 class="field-label" id="writing-label">Writing</h2>
    {
      writingGroups.length === 0 ? (
        <p class="empty">準備中。</p>
      ) : (
        <ol class="writing">
          {writingGroups.map(([year, items]) =>
            items.map((entry, i) => (
              <li>
                <a
                  class="row"
                  href={entry.href}
                  target={entry.external ? '_blank' : undefined}
                  rel={entry.external ? 'noopener noreferrer' : undefined}
                >
                  <span class="year" aria-hidden={i !== 0}>
                    {i === 0 ? year : ''}
                  </span>
                  <span class="entry">
                    <span class="title">{entry.title}</span>
                    {entry.source === 'zenn' && <span class="ext">zenn</span>}
                  </span>
                </a>
              </li>
            )),
          )}
        </ol>
      )
    }
  </section>

  <section class="field" id="projects" aria-labelledby="projects-label">
    <h2 class="field-label" id="projects-label">Projects</h2>
    <ol class="projects">
      {
        projects.map((p) => (
          <li>
            <a class="row" href={p.href} target="_blank" rel="noopener noreferrer">
              <span class="name">{p.name}</span>
              <span class="desc">{p.desc}</span>
            </a>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="field" id="contact" aria-labelledby="contact-label">
    <h2 class="field-label" id="contact-label">Contact</h2>
    <ul class="contact">
      {
        contact.map((c) => (
          <li>
            <a
              href={c.href}
              aria-label={c.aria}
              target={c.href.startsWith('mailto:') ? undefined : '_blank'}
              rel={c.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
            >
              {c.label}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Base>
